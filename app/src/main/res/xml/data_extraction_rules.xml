<?xml version="1.0" encoding="utf-8"?>
<!--
    Règles d'extraction de données Android 12+ (dataExtractionRules).
    Inclut le cache Coil dans la sauvegarde cloud (Google Drive) et dans
    le transfert device-to-device (migration vers un nouveau téléphone).
    Limite : 25 MB max sur Google Drive (le cache Coil est configuré à 25 MB).
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="external" path="coil_image_cache" />
    </cloud-backup>
    <device-transfer>
        <include domain="external" path="coil_image_cache" />
    </device-transfer>
</data-extraction-rules>
