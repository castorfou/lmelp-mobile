# Copier ce fichier en .env et adapter les valeurs à votre environnement local
# Ce fichier .env est ignoré par git (voir .gitignore)

# URI MongoDB
LMELP_MONGO_URI=mongodb://localhost:27017

# Chemin vers la base Calibre (metadata.db)
LMELP_CALIBRE_DB=/path/to/Calibre Library/metadata.db

# Tag de la virtual library Calibre à utiliser pour filtrer les livres onkindle
# (ex: 'guillaume', 'camille' — correspond à un tag dans Calibre)
LMELP_CALIBRE_VIRTUAL_LIBRARY=

# Chemin de sortie de la base SQLite
LMELP_OUTPUT=app/src/main/assets/lmelp.db
